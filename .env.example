# ─── Supabase Configuration ────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings > API
# These values are safe to expose to the browser.

# The URL of your Supabase project (e.g. https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# The anonymous (anon/publishable) key — safe for client-side use
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Server-Only Secrets ─────────────────────────────────────────────────────
# The service_role key has full access to your database.
# NEVER expose this to the browser. It is used only in API routes and middleware.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Generate an API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Verified sender domain address
EMAIL_FROM=KeebForge <orders@keebforge.in>
# Your app URL for building tracking links
NEXT_PUBLIC_APP_URL=http://localhost:3000
